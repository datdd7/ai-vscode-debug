# AI Debug Proxy — Test Environment Configuration
# Copy to .env and fill in values for local development

# Test environment (local | staging | production)
TEST_ENV=local

# Debug proxy base URL (E2E tests target this)
BASE_URL=http://localhost:9999
API_URL=http://localhost:9999

# Pact Broker (contract testing — required for publish/can-i-deploy)
PACT_BROKER_BASE_URL=https://your-pactflow-instance.pactflow.io
PACT_BROKER_TOKEN=your-pactflow-api-token
