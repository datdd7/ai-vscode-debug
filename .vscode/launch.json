{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(gdb) Playground",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/playground/build/cooling_ecu",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/playground",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set disassembly flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build-playground"
        },
        {
