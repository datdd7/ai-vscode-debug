@startuml Sequence Diagram - Launch
title Sequence Diagram: GDB Launch via REST API

actor Agent as "AI Agent"
participant Router as "Router"
participant BackendManager as "BackendManager"
participant GDBBackend as "GDBBackend"
participant MI2 as "MI2"
participant GDB as "GDB Process"

Agent -> Router : POST /api/debug/execute_operation { op: 'launch' }
Router -> BackendManager : getBackend('gdb')
BackendManager -> GDBBackend : start(config)
GDBBackend -> MI2 : start(application, args)
MI2 -> GDB : spawn()
GDB --> MI2 : (gdb) prompt
MI2 --> GDBBackend : started
GDBBackend --> BackendManager : ready
BackendManager --> Router : success
Router --> Agent : 200 OK { success: true }

@enduml
