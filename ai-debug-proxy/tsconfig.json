{
    "compilerOptions": {
        "module": "commonjs",
        "target": "ES2022",
        "outDir": "out",
        "lib": [
            "ES2022"
        ],
        "sourceMap": true,
        "rootDir": "src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "types": ["vitest/globals", "node"]
    },
    "exclude": [
        "node_modules",
        "out",
        "src/test/suite/**"
    ],
    "include": [
        "src/**/*"
    ]
}